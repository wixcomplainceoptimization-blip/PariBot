# Telegram Bot Token (get from @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# Odds API Key (get from https://the-odds-api.com/)
ODDS_API_KEY=your_odds_api_key_here

# Sport(s) to track (comma-separated)
SPORTS=football,basketball,tennis,baseball

# Default region for odds
DEFAULT_REGION=eu

# Refresh interval in seconds
REFRESH_INTERVAL=300

# Database URL (for Railway, use postgres://...)
DATABASE_URL=sqlite:///paribot.db
